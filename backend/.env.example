# ─── Required ────────────────────────────────────────────────────────────────

# Postgres DSN. Must start with postgres:// or postgresql://.
# In the compose setup the host is the `postgres` service; sslmode=disable is
# fine on the internal network. For an external/managed DB use sslmode=require.
DATABASE_URL=postgres://stevio:CHANGE_ME@postgres:5432/stevio?sslmode=disable

SIGNING_KEY_SECRET=<64-char hex string (32 bytes), generate with: store-cli generate signing-secret>
SESSION_SECRET=<64-char hex string (32 bytes), generate with: store-cli generate secret>
EMAIL_HASH_SALT=<64-char hex string (32 bytes), generate with: store-cli generate salt>

# ─── Optional ────────────────────────────────────────────────────────────────

# SMTP — if unset, emails are logged to stdout instead of sent
SMTP_HOST=smtp.example.com
SMTP_USER=user@example.com
SMTP_PASS=secret
SMTP_PORT=587
SMTP_FROM=noreply@example.com

# Base URL of your store (used in sitemap, robots.txt, SEO meta tags, magic links).
# In production set this to your public https:// origin.
BASE_URL=http://localhost:3000
ENV=development
PORT=8080

# CORS allowed origin — only honoured when ENV=development (ignored in production).
CORS_ORIGIN=http://localhost:5173

# Admin access — comma-separated email addresses. Hashed at startup with
# EMAIL_HASH_SALT and seeded into the users table with role=admin.
ADMIN_EMAILS=admin@example.com

# File storage directories (defaults work with the Docker setup)
ASSETS_DIR=/assets
APPS_DIR=/apps

# ─── Payment Providers ──────────────────────────────────────────────────────

# Paddle Billing credentials are configured via the admin UI (/admin/payment)
# and stored encrypted in site_settings under SIGNING_KEY_SECRET. No env vars
# needed here. The mock provider derives its webhook secret deterministically
# from SIGNING_KEY_SECRET.
